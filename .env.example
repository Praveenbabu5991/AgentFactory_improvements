# =============================================================================
# Agent Factory - Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# Google AI API Key (required for image/video generation)
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------
# Orchestrator model (text/reasoning for all agents)
DEFAULT_MODEL=gemini-2.5-flash
# Image generation model (used inside image_gen tools)
IMAGE_MODEL=gemini-3-pro-image-preview
# Video generation model (used inside video_gen tools)
VIDEO_MODEL=veo-3.1-generate-preview

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
CONTENT_STUDIO_PORT=5000
VIDEO_STUDIO_PORT=5002
DEBUG=true
ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Storage backend: "local" (default) or "s3" or "gcs"
STORAGE_BACKEND=local
# For S3/GCS:
# STORAGE_BUCKET=my-studio-assets
# STORAGE_CDN_URL=https://cdn.example.com

# ---------------------------------------------------------------------------
# Upload Limits
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MAX_IMAGE_DIMENSION=4096

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=60

# ---------------------------------------------------------------------------
# Sessions
# ---------------------------------------------------------------------------
SESSION_TIMEOUT_HOURS=24

# ---------------------------------------------------------------------------
# Persistence (LangGraph Checkpointer)
# ---------------------------------------------------------------------------
# Database backend: "sqlite" (default) or "postgres"
DATABASE_BACKEND=sqlite
# SQLite (development)
DATABASE_URL=sqlite:///data/studio.db
# Postgres (production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/agent_factory

# ---------------------------------------------------------------------------
# LangSmith Tracing (optional but recommended)
# ---------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agent-factory
